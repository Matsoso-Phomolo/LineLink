APP_ENV=local
SEED_DEMO_DATA=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-secure-password
ADMIN_FULL_NAME=LineLink Admin
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/linelink
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,https://your-linelink-frontend.vercel.app
MPESA_BASE_URL=https://mpesa-provider.example
MPESA_CLIENT_ID=replace-with-render-env-value
MPESA_CLIENT_SECRET=replace-with-render-env-value
MPESA_SHORT_CODE=replace-with-provider-short-code
MPESA_CALLBACK_URL=https://your-render-backend.onrender.com/payments/callback/mpesa
ECOCASH_BASE_URL=https://ecocash-provider.example
ECOCASH_CLIENT_ID=replace-with-render-env-value
ECOCASH_CLIENT_SECRET=replace-with-render-env-value
ECOCASH_MERCHANT_CODE=replace-with-provider-merchant-code
ECOCASH_CALLBACK_URL=https://your-render-backend.onrender.com/payments/callback/ecocash
